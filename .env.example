NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app/site (usada para montar as URLs de retorno do checkout).
# Em produção: https://app.nexo.events (ou o domínio da Vercel). Em dev pode
# ficar vazio — o checkout usa a origin da requisição como fallback.
NEXT_PUBLIC_SITE_URL=

# AbacatePay (billing) — criar conta pessoal do Nexo (nunca a da Prolog).
# ABACATE_API_KEY: chave secreta da API (dev e prod são chaves diferentes).
# ABACATE_WEBHOOK_SECRET: segredo que VAI na URL do webhook como ?webhookSecret=...
#   (você define; configure a mesma string no painel da Abacate).
# Os IDs dos produtos do Fundador ficam FIXOS no código (não são segredo) —
# ver app/api/billing/checkout/route.ts. Use os mesmos slugs na conta de produção.
ABACATE_API_KEY=
ABACATE_WEBHOOK_SECRET=
